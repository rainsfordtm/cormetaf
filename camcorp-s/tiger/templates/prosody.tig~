// Templates for the study of the prosodic properties of groups in the corpus.

Polysyllable(#n0) <-
	#n0:[syllabified = /.+\..+/] ; // Syllabified contains a dot

Monosyllable(#n0) <-
	#n0:[syllabified = /[^\.]*\/[^\\]+\\[^\.]*/] ;
	
Disyllable(#n0) <- // Disyllabic paroxytone
	#n0:[syllabified = /[^\.]+\.[^\.]+/] ;
	
Oxytone(#n0) <- // Polysyllabic oxytone
	#n0:[syllabified = /.+\.'[^\.]+/] ;
	
Paroxytone(#n0) <-
	#n0:[syllabified = /.*'[^\.]+\.[^\.]+/] ;
	
CliticPrn(#n0) <-
	#n0:[syntag2=/(\$\$)|(%%)|(\$%)|(%\$)/] ;
	
// A critical subroutine. The conservative routine works on the principle that
// monosyllables which (i) were always monosyllables and (ii) do NOT show
// a syllable structure compatible with the minimal word in OF OR
// (iii) are formally identical to prefixes.
// There are still some borderline cases: ço/jo/là/jà which are not included;
// equally the forms with enclitic pronouns or determiners.

UnstressedConservative(#n0) <-
	Monosyllable(#n0) 
	& (
		#n0:[lemma = /le|en1|à|de|par1|pour|et|ou1|ne2|que|si3|ne1|en2|y/]
		| #n0:[lemma = /[0-9]p.*|soi/ & syntag2 = /.*\$\$|.*%%|\$%|%\$/]
	) ;
	
StressedConservative(#n0) <-
	Polysyllable(#n0)
	| (Monosyllable(#n0) & #n0:[lemma != /le|en1|à|de|par1|pour|et|ou1|ne2|que|si3|ne1|en2|y|[0-9]p.*|soi/]) 
	| (Monosyllable(#n0) & #n0:[lemma = /[0-9]p.*|soi/ & syntag2 != /.*\$\$|.*%%|\$%|%\$/]) ;

// The less conservative subroutine works on the principle that ONLY LEXICAL CATEGORIES
// count as stressed and that the verbs avoir and être can't.
// This has the advantage of reducing the number problematic tokens to those which are
// genuinely interesting at the cost of losing a few positional stresses.

Unstressed(#n0) <-
	Monosyllable(#n0)
	& (
		#n0:[syntag2 != /N|Adj|Adv|Dem|Vpp|Vinf|Vprs|Prn/]
		| #n0:[syntag2 = /QIs|Vfin|PrA/ & lemma = /un|avoir1|être1.*|sur/]
	) ;

Stressed(#n0) <-
	Monosyllable(#n0) // function only applies to MS; reduction of disjunctions
	& (
		#n0:[syntag2 = /N|Adj|Adv|Dem|Vpp|Vinf|Vprs|Prn/]
		| #n0:[syntag2 = /QIs|Vfin|PrA/ & lemma != /un|avoir1|être1.*|sur/]
	) ;
	
HasSyllables(#n0) <-
	#n0:[syllabified != /([^\.]*\/\\.*)|(\-\-)/] ;
	
HasNoSyllables(#n0) <-
	#n0:[syllabified = /([^\.]*\/\\.*)|(\-\-)/] ;
	
Adjacent(#n0, #n1) <-
	// Takes account of intervening word with no phonetic content (roughly)
	#n0 . #n1
	| ( #n0 . #x & #x . #n1 & HasNoSyllables(#x))
	| ( #n0 . #x & #x . #y & #y . #n1 & HasNoSyllables(#x) & HasNoSyllables(#y)) ;
	
ShortNT(#n0) <-
	// Short groups are under five syllables in length
	#n0:[slength = /[1234]/] ;
	
LongNT(#n0) <-
	// Long groups are over five syllables in length
	#n0:[slength = /..+|[56789]/] ;
	
AtEndS(#w1) <-
	// Word occurs at the right-edge of the graph, i.e. the sentence
	root(#n) & #n >@r #w1 ;
	
AtEndLongXP(#w1) <-
	// Word occurs at the right-edge of a clause or a long XP NOT a V group.
	#p > #w1:[word=/.*/] & #p >@r #w1 & #gp > #p 
	& (
		// Parent is Long
		LongNT(#p)
		|
		// OR Parent is short but word is last in grandparent, and that's long
		( ShortNT(#p) & #gp >@r #w1 & LongNT(#gp) )
		|
		// OR Grandparent is short BUT word is last in great-grandparent
		( ShortNT(#gp) & #ggp > #gp & #ggp >@r #w1 )
	) ;
	
NotAtEndLongXP(#w1) <-
	// Word does NOT occur at the right-edge of a clause or a long XP
	#p > #w1:[word=/.*/]
	& #gp > #p
	& (
		// #w1 is not the last word in its parent
		( #p >@r #w & #w1 .* #w )
		| 
		// OR it is the last word in a short or V parent and not final in the grandparent
		( #p >@r #w1 & ( ShortNT(#p) | (LongNT(#p) & #p:[cat="V"]) ) & #gp >@r #w & #w1 .* #w )
		|
		// OR it is the last word in the grandparent and something is parent of the grandparent
		// in which the word is NOT final.
		( #gp >@r #w1 & ShortNT(#gp) & #x > #gp & #x >@r #w & #w1 .* #w )
	) ;
	
